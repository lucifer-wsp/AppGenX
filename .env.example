# ========== LLM 后端（三选一，推荐 Cursor）==========

# 自动选择：有 CURSOR_API_KEY 用 Cursor，否则有 LLM_API_KEY 用 OpenAI，都没有则 Mock
LLM_PROVIDER=auto
# 强制指定：auto | mock | cursor | openai

# --- 方案 A：Cursor（推荐，走 Cursor 订阅，无需单独买 OpenAI/DeepSeek）---
# 在 https://cursor.com/dashboard/integrations 创建 API Key
CURSOR_API_KEY=cursor_your_key
# 默认流水线模型（Scout/PM/Design 等）
CURSOR_MODEL=composer-2.5

# 可选：扫描分析阶段独立模型（留空则使用上方默认）
# CURSOR_ANALYZE_MODEL=gpt-4o-mini
# LLM_ANALYZE_MODEL=gpt-4o-mini

# 可选：DevCode/DevVerify 编码阶段独立模型（留空则使用默认）
# CURSOR_CODE_MODEL=composer-2.5
# LLM_CODE_MODEL=gpt-4o

# --- 方案 B：OpenAI 兼容 API（可选）---
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# 可选：联网搜索（竞品调研）
SERPER_API_KEY=

# 工作区
APPGEN_WORKSPACE=./workspace

# Web Dashboard
APPGEN_HOST=127.0.0.1
APPGEN_PORT=8787

# 默认 App Store 区域：us | eu | us-eu（美区+欧洲，不含中国大陆）
APPGEN_DEFAULT_REGIONS=us-eu

# 访问 App Store 榜单 API 的 HTTP 代理（国内网络通常需要）
# APPGEN_HTTP_PROXY=http://127.0.0.1:7890

# 市场扫描并发（默认 10；遇 HTTP 429 限流时可降至 4–6）
# APPGEN_SCAN_CONCURRENCY=10
# APPGEN_SCAN_MAX_CONCURRENCY=20

# 人机 Review：auto=自动通过（开发模式）, cli=命令行确认, web=Web 面板确认
APPGEN_REVIEW_MODE=cli
